# Canary — LLM Drift Monitor
# Copy to .env and fill in your values

# Required: OpenRouter API key (https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: Direct provider keys (legacy, OpenRouter recommended)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Webhook alerts
# CANARY_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
# CANARY_SLACK_WEBHOOK=https://hooks.slack.com/services/...
# CANARY_WEBHOOK=https://your-endpoint.com/hook
